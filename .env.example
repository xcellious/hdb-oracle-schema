# Flyway Database Configuration
# Copy this file to '.env' and fill in your actual credentials.
# Do NOT commit '.env' to version control!

# Database Connection URL (e.g. jdbc:oracle:thin:@//localhost:1521/FREEPDB1)
FLYWAY_URL=jdbc:oracle:thin:@//localhost:1521/FREEPDB1

# Administrative Database User (usually 'sys' for Oracle migrations)
FLYWAY_USER=sys

# Administrative Database Password
FLYWAY_PASSWORD=your_admin_password_here

# HDB Application User Placeholder (used to replace '${hdb_user}' in SQL scripts)
FLYWAY_PLACEHOLDERS_HDB_USER=HDBDBA

# HDB Application Password Placeholder (used to replace '${hdb_password}' in SQL scripts)
FLYWAY_PLACEHOLDERS_HDB_PASSWORD=your_hdb_password_here
